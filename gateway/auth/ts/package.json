{
  "name": "gatekey",
  "version": "0.1.1",
  "description": "Three-layer macaroon signer, attenuator, and verifier for cryptographic LLM governance",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "tsx --test test/*.test.ts",
    "regenerate-fixtures": "tsx scripts/regenerate-fixtures.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "macaroon",
    "auth",
    "authorization",
    "llm",
    "ed25519",
    "secp256k1",
    "ecdsa",
    "hmac",
    "jcs",
    "rfc8785",
    "cryptography",
    "delegation",
    "attenuation",
    "caveats"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stakwork/stakgraph.git",
    "directory": "gateway/auth/ts"
  },
  "homepage": "https://github.com/stakwork/stakgraph/tree/main/gateway/auth/ts#readme",
  "bugs": {
    "url": "https://github.com/stakwork/stakgraph/issues"
  },
  "author": "Stakwork",
  "license": "MIT",
  "dependencies": {
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0",
    "canonicalize": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
