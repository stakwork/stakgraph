{
  "name": "stackgraph-mcp-server",
  "version": "0.1.0",
  "description": "MCP Server with Stackgraph tool",
  "type": "module",
  "private": true,
  "workspaces": {
    "packages": [
      "src/aieo",
      "src/gitsee/agent"
    ],
    "nohoist": [
      "**/gitsee*/aieo"
    ]
  },
  "resolutions": {
    "@ai-sdk/anthropic": "3.0.75",
    "@ai-sdk/google": "3.0.67",
    "@ai-sdk/openai": "3.0.61",
    "@ai-sdk/gateway": "3.0.110",
    "ai": "6.0.175",
    "@ai-sdk/xai": "3.0.88"
  },
  "scripts": {
    "dev": "([ -n \"$CI\" ] || npm run refresh-vein); tsx src/index.ts",
    "build": "tsc",
    "start": "node build/index.js",
    "gitree": "tsx src/gitree/cli.ts",
    "refresh-vein": "cd ../vein && npm run build && npm run build:web && cd ../mcp && rm -rf node_modules/vein && yarn install --force",
    "sphinx-git": "tsx src/sphinx-git/bin.ts",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "gen-redoc": "tsc --noEmit && tsx docs/gen-redoc.ts",
    "copydir": "node docs/copydir/index.js",
    "build-app1": "tsc --noEmit && tsc --target esnext --module commonjs --outDir build/app app/app.ts",
    "build-app": "node build-app.js",
    "build-web": "cd web && npm install && npm run build",
    "build-benchmark": "cd benchmark && npm install && npm run build",
    "build-all": "npm run build && npm run build-web && npm run build-benchmark"
  },
  "bin": {
    "cursor-tools": "./build/index.js",
    "gitree": "./build/gitree/cli.js",
    "sphinx-git": "./build/sphinx-git/bin.js"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.75",
    "@ai-sdk/mcp": "1.0.18",
    "@anthropic-ai/sdk": "0.37.0",
    "@aws-sdk/client-cloudwatch-logs": "3.994.0",
    "@aws-sdk/credential-providers": "3.994.0",
    "@browserbasehq/stagehand": "3.0.8",
    "@hono/node-server": "2.0.4",
    "@microsoft/tiktokenizer": "1.0.10",
    "@modelcontextprotocol/sdk": "1.26.0",
    "@noble/ed25519": "2.3.0",
    "@noble/hashes": "1.7.1",
    "@octokit/rest": "22.0.1",
    "@openrouter/ai-sdk-provider": "6.0.0-alpha.1",
    "@playwright/test": "1.58.1",
    "ai": "6.0.175",
    "archy": "1.0.0",
    "axios": "1.13.4",
    "commander": "14.0.3",
    "cors": "2.8.6",
    "dotenv": "16.6.1",
    "express": "4.22.1",
    "express-fileupload": "1.5.2",
    "fast-glob": "3.3.3",
    "fastembed": "2.1.0",
    "git-url-parse": "16.1.0",
    "gitsee": "1.0.18",
    "gitsee-agent": "1.0.19",
    "js-yaml": "4.1.1",
    "jsonwebtoken": "9.0.3",
    "nanoid": "5.1.6",
    "neo4j-driver": "5.28.3",
    "node-cache": "5.1.2",
    "p-queue": "^6.6.2",
    "simple-git": "3.30.0",
    "uuid": "11.1.0",
    "vein": "file:../vein",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/archy": "0.0.36",
    "@types/commander": "2.12.5",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/express-fileupload": "1.5.1",
    "@types/git-url-parse": "9.0.3",
    "@types/js-yaml": "4.0.9",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "22.19.9",
    "@types/node-cache": "4.2.5",
    "@types/xmldom": "0.1.34",
    "clipboardy": "4.0.0",
    "esbuild": "0.25.12",
    "htm": "3.1.1",
    "preact": "10.28.3",
    "ts-node": "10.9.2",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "scarfSettings": {
    "enabled": false
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
